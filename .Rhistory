dados <- data.frame(
resposta = c(rnorm(60, mean = 20, sd = 3), rnorm(60, mean = 25, sd = 3)),
fator_A = rep(c("A1", "A2", "A3"), each = 40),
fator_B = rep(c("B1", "B2"), each = 60)
)
dados <- data.frame(
resposta = c(rnorm(60, mean = 20, sd = 3), rnorm(60, mean = 25, sd = 3)),
fator_A = rep(c("A1", "A2", "A3"), each = 40),
fator_B = rep(c("B1", "B2"), each = 60)
)
dados
# Modelo com interação (sinal de asterisco '*')
modelo_interacao <- aov(resposta ~ fator_A * fator_B, data = dados)
summary(modelo_interacao)
# Modelo sem interação (sinal de adição '+')
modelo_sem_interacao <- aov(resposta ~ fator_A + fator_B, data = dados)
summary(modelo_sem_interacao)
# Comparar os dois modelos usando a função anova() ou AIC
anova(modelo_sem_interacao, modelo_interacao)
AIC(modelo_interacao, modelo_sem_interacao)
?aov
